# =============================================================================
# RPi RFID Access Control — Configuration
# =============================================================================
# Copy this file to .env and customize the values.
# Do NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Hardware Configuration
# -----------------------------------------------------------------------------

# Use mock hardware for development without a real Raspberry Pi / RFID reader.
# Set to false when deploying to actual Pi hardware.
USE_MOCK_HARDWARE=true

# RFID reader type. Options:
#   mfrc522 — SPI-connected hobby module (MFRC522)
#   pn532   — NFC-capable reader (PN532)
#   rs232   — Industrial RS-232 reader (Wiegand-to-serial)
#   mock    — Software simulation only
READER_TYPE=mock

# GPIO pin for the relay controlling the door lock.
# BCM numbering. Default GPIO 17 = physical pin 11.
RELAY_GPIO_PIN=17

# Optional: GPIO pin for door switch (tamper detection).
# Leave commented if not used.
# DOOR_SWITCH_GPIO_PIN=18

# RS-232 reader serial port (only if READER_TYPE=rs232)
RS232_PORT=/dev/ttyUSB0
RS232_BAUDRATE=9600

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

DATABASE_PATH=./data/access.db
BACKUP_INTERVAL_HOURS=24
BACKUP_PATH=./backups/

# -----------------------------------------------------------------------------
# Web Server
# -----------------------------------------------------------------------------

WEB_HOST=0.0.0.0
WEB_PORT=8000

# Admin credentials for the web UI.
# Generate the bcrypt hash with: python scripts/hash_password.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$EXAMPLE_REPLACE_WITH_REAL_BCRYPT_HASH

# Session secret (random 32+ char string)
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# -----------------------------------------------------------------------------
# Access Control Behavior
# -----------------------------------------------------------------------------

# How long the door stays unlocked after a successful read (seconds)
DOOR_OPEN_DURATION_SECONDS=5

# Fail-safe mode: door opens on power loss (life safety)
# Set to false for fail-secure (door stays locked on power loss)
FAIL_SAFE_MODE=true

# Lockout after N failed reads (rate limiting)
RATE_LIMIT_FAILED_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

LOG_LEVEL=INFO
LOG_FILE=./logs/access.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
